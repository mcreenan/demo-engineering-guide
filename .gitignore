node_modules/
.DS_Store
/tmp/

# palimpsest build output.
# These are COMMITTED so GitHub Pages can publish them: run `pal build` and
# commit the result before pushing to main (.github/workflows/deploy-pages.yml).
# Still ignored: the root redirect (generated in CI) and any scratch dist/.
/index.html
/dist/

# generated agent prompts (pal outline / pal draft)
/.palimpsest/

# local source material (clone code repos / place docs here; tracked via .gitkeep)
/sources/code/*
!/sources/code/.gitkeep
/sources/docs/*
!/sources/docs/.gitkeep
